@model CreateSwapViewModel

<h3>طلب تبادل مع: @Model.RequestedItemName</h3>
<p>سعر المنتج المطلوب: @Model.RequestedItemPrice.ToString("C")</p>

<form asp-action="CreateSwap" method="post">
    <input type="hidden" asp-for="RequestedItemId" />

    <div class="form-group">
        <label>اختر منتجك للمبادلة (المنتجات ذات السعر المتقارب فقط):</label>
        <select asp-for="OfferedItemId" class="form-control">
            <option value="">-- اختر المنتج --</option>
            @foreach (var item in Model.MyAvailableItems)
            {
                <option value="@item.ItemID">@item.Title (@item.Price.ToString("C"))</option>
            }
        </select>
        <span asp-validation-for="OfferedItemId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-3">إرسال الطلب</button>
</form>