@{
    ViewData["Title"] = "Top Up Wallet";
    var currentBalance = (decimal)(ViewBag.CurrentBalance ?? 0m);
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">

            <div class="text-center mb-5">
                <div class="topup-icon-circle mx-auto mb-3">
                    <i class="bi bi-wallet2 fs-1 text-white"></i>
                </div>
                <h1 class="fw-bold mb-1">Top Up Wallet</h1>
                <p class="text-muted">Add funds to your account for secure Escrow purchases</p>
            </div>

            <div class="balance-display mb-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <small class="text-muted d-block mb-1">Current Balance</small>
                        <h2 class="fw-bold mb-0 text-orange" id="currentBalanceDisplay">$@currentBalance.ToString("0.00")</h2>
                    </div>
                    <div class="balance-icon">
                        <i class="bi bi-piggy-bank-fill"></i>
                    </div>
                </div>
            </div>

            <div class="mb-4">
                <small class="text-muted fw-semibold d-block mb-2">Quick Amounts:</small>
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var amt in new[] { 10, 50, 100, 200, 500 })
                    {
                        <button type="button" class="btn btn-quick-amount rounded-pill fw-semibold" onclick="setAmount(@amt)">$@amt</button>
                    }
                </div>
            </div>

            <div class="topup-card">
                <form id="topupForm">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label for="topupAmount" class="form-label fw-semibold">Enter Amount (USD)</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-orange text-white border-0 fw-bold">$</span>
                            <input type="number" id="topupAmount" name="amount" class="form-control border-2" placeholder="0.00" min="1" max="10000" step="0.01" oninput="updatePreview(this.value)">
                        </div>
                    </div>

                    <div id="previewBox" class="preview-box mb-4" style="display:none;">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted">New Balance</span>
                            <span class="fw-bold text-orange fs-5" id="newBalance">$0.00</span>
                        </div>
                    </div>

                    <button type="submit" id="topupSubmitBtn" class="btn btn-orange w-100 fw-bold py-3 rounded-pill text-white shadow">
                        Confirm Top Up
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="topupToast" class="toast align-items-center border-0 rounded-4 shadow-lg" role="alert">
        <div class="d-flex">
            <div class="toast-body fw-semibold" id="topupToastMsg"></div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<style>
    .text-orange {
        color: #f97316 !important;
    }

    .bg-orange {
        background-color: #f97316 !important;
    }

    .btn-orange {
        background: linear-gradient(135deg, #f97316, #fb923c);
        border: none;
    }

    .topup-icon-circle {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #f97316, #fb923c);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .balance-display {
        background: #fff7ed;
        border: 2px solid #fed7aa;
        border-radius: 18px;
        padding: 20px;
    }

    .btn-quick-amount {
        background: #fff7ed;
        color: #f97316;
        border: 1.5px solid #fed7aa;
    }

    .topup-card {
        background: white;
        border-radius: 24px;
        padding: 28px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }
</style>

@section Scripts {
    <script>
        const currentBalance = @currentBalance;
        function setAmount(val) {
            document.getElementById('topupAmount').value = val;
            updatePreview(val);
        }
        function updatePreview(val) {
            const amount = parseFloat(val);
            const box = document.getElementById('previewBox');
            if (isNaN(amount) || amount <= 0) { box.style.display = 'none'; return; }
            box.style.display = 'block';
            document.getElementById('newBalance').textContent = '$' + (currentBalance + amount).toFixed(2);
        }

        document.getElementById('topupForm').addEventListener('submit', function (e) {
            e.preventDefault();
            const amount = document.getElementById('topupAmount').value;
            const btn = document.getElementById('topupSubmitBtn');
            btn.disabled = true;

            const formData = new FormData();
            formData.append('amount', amount);
            formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

            fetch('/Transactions/TopUpWallet', { method: 'POST', body: formData })
                .then(r => r.json())
                .then(data => {
                    showToast(data.message, data.success ? 'success' : 'danger');
                    if (data.success) setTimeout(() => window.location.href = '/Transactions/MyOrders', 2000);
                    else btn.disabled = false;
                });
        });

        function showToast(message, type) {
            const toast = document.getElementById('topupToast');
            toast.className = `toast align-items-center border-0 rounded-4 shadow-lg text-bg-${type}`;
            document.getElementById('topupToastMsg').textContent = message;
            new bootstrap.Toast(toast).show();
        }
    </script>
}