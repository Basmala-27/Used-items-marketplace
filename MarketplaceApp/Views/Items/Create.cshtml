@model ItemCreateViewModel

@{
    ViewData["Title"] = "Post a New Item";
}

<div class="container mt-4 mb-5" style="max-width: 850px;">
    <!-- الهيدر -->
    <div class="mb-4">
        <h2 class="fw-bold">Post a New Item</h2>
        <p class="text-muted">Fill in the details to list your item</p>
    </div>

    <form asp-action="Create" enctype="multipart/form-data" method="post">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <!-- قسم الصور (Screenshot 2026-04-30 032112.png) -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Item Photos</label>
                    <div class="upload-container text-center p-5" id="drop-zone">
                        <div id="image-preview-container" class="mt-3 d-flex flex-wrap gap-2">
                            <!-- الصور هتظهر هنا بالـ JavaScript -->
                        </div>
                        <div id="upload-status" class="text-success fw-bold small mt-2" style="display:none;">
                            <i class="bi bi-check-circle-fill"></i> تمت إضافة الصور بنجاح!
                        </div>
                        <i class="bi bi-upload fs-1 mb-2"></i>
                        <div class="mb-1">Click to upload or drag and drop</div>
                        <div class="text-muted small">PNG, JPG up to 10MB (max 5 images)</div>
                        <!-- خانة رفع الملفات مخفية وبنفتحها بالضغط على الـ Container -->
                        <input type="file" asp-for="ImageFiles" multiple class="d-none" id="file-input" accept="image/*" />
                    </div>
                    <span asp-validation-for="ImageFiles" class="text-danger small"></span>
                </div>

                <!-- العنوان -->
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Item Title *</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g., Sony WH-1000XM4 Wireless Headphones" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <!-- القسم والحالة (Row) -->
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="CategoryID" class="form-label fw-bold">Category *</label>
                        <select asp-for="CategoryID" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">Select category</option>
                        </select>
                        <span asp-validation-for="CategoryID" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Condition" class="form-label fw-bold">Condition *</label>
                        <select asp-for="Condition" asp-items="ViewBag.Conditions" class="form-select">
                            <option value="">Select condition</option>
                        </select>
                        <span asp-validation-for="Condition" class="text-danger small"></span>
                    </div>
                </div>

                <!-- الوصف -->
                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Description *</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe your item in detail..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <!-- السعر والموقع (Screenshot 2026-04-30 032124.png) -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label fw-bold">Price (USD) *</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0">$</span>
                            <input asp-for="Price" class="form-control border-start-0" placeholder="0.00" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Location" class="form-label fw-bold">Location *</label>
                        <input asp-for="Location" class="form-control" placeholder="City, State" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>
                </div>

                <!-- Checkboxes الاختيارية -->
                <div class="mb-4">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="negotiable">
                        <label class="form-check-label" for="negotiable">Price is negotiable</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="swapOffers">
                        <label class="form-check-label" for="swapOffers">Open to swap/trade offers</label>
                    </div>
                </div>

                <!-- أزرار التحكم -->
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-orange flex-grow-1 py-2 fw-bold">Post Item</button>
                    <a asp-action="Index" class="btn btn-light border px-4 py-2">Cancel</a>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const dropZone = document.getElementById('drop-zone');
        const fileInput = document.getElementById('file-input');
        const previewContainer = document.getElementById('image-preview-container');
        const uploadStatus = document.getElementById('upload-status');

        // مصفوفة (Array) عشان نخزن فيها الصور اللي بنختارها وما تروحش لما نختار جديد
        let selectedFiles = [];

        // فتح النافذة لما نضغط على الـ drop zone (بشرط ما يكونش الضغط على زرار المسح)
        dropZone.addEventListener('click', (e) => {
            if (e.target.tagName !== 'SPAN') {
                fileInput.click();
            }
        });

        fileInput.addEventListener('change', function () {
            // إضافة الملفات الجديدة للمصفوفة القديمة
            const newFiles = Array.from(this.files);
            selectedFiles = selectedFiles.concat(newFiles);

            updateUI();
        });

        function updateUI() {
            previewContainer.innerHTML = '';

            if (selectedFiles.length > 0) {
                uploadStatus.style.display = 'block';
                uploadStatus.innerHTML = `<i class="bi bi-check-circle-fill"></i> جاري التحميل... (${selectedFiles.length} صور)`;

                selectedFiles.forEach((file, index) => {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        const imgWrapper = document.createElement('div');
                        imgWrapper.className = "position-relative";
                        imgWrapper.style.width = "90px";

                        imgWrapper.innerHTML = `
                            <img src="${e.target.result}" class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;">
                            <span class="position-absolute top-0 start-0 translate-middle badge rounded-circle bg-danger"
                                  style="cursor:pointer; padding: 0.35em 0.6em; z-index: 10;"
                                  onclick="removeFile(${index}, event)">×</span>
                        `;
                        previewContainer.appendChild(imgWrapper);
                    };
                    reader.readAsDataURL(file);
                });

                // تحديث الـ Input الفعلي بالملفات النهائية عشان لما الفورم تتبعت
                syncFilesToInput();
            } else {
                uploadStatus.style.display = 'none';
            }
        }

        // ميثود لمسح صورة محددة
        window.removeFile = function(index, event) {
            event.stopPropagation(); // منع فتح نافذة اختيار الملفات
            selectedFiles.splice(index, 1); // مسح الصورة من المصفوفة
            updateUI(); // تحديث الشكل
        };

        // ميثود لربط المصفوفة بالـ Input عشان الداتا تتبعت للـ Controller
        function syncFilesToInput() {
            const dataTransfer = new DataTransfer();
            selectedFiles.forEach(file => dataTransfer.items.add(file));
            fileInput.files = dataTransfer.files;
        }

        // Drag & Drop
        dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.style.borderColor = '#FF6600'; });
        dropZone.addEventListener('dragleave', () => { dropZone.style.borderColor = '#d1d5db'; });
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            const droppedFiles = Array.from(e.dataTransfer.files);
            selectedFiles = selectedFiles.concat(droppedFiles);
            updateUI();
        });
    </script>
}