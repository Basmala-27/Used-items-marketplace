@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Inter', sans-serif;
        background-color: #f8f9fa;
    }

    .admin-card {
        transition: all 0.3s ease;
        border: none;
        border-radius: 20px;
        overflow: hidden;
    }

        .admin-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .icon-box {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }

    /* Colors Styles */
    .bg-primary-soft {
        background-color: #e7f1ff;
        color: #0d6efd;
    }

    .bg-success-soft {
        background-color: #e6f7ef;
        color: #198754;
    }

    .bg-danger-soft {
        background-color: #fceaea;
        color: #dc3545;
    }

    .bg-warning-soft {
        background-color: #fff9e6;
        color: #ffc107;
    }

    .btn-custom {
        border-radius: 12px;
        padding: 10px 15px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.85rem;
    }
</style>

<div class="container py-5">
    <div class="text-center mb-5">
        <span class="badge bg-primary px-3 py-2 mb-3 rounded-pill">Admin Management System</span>
        <h1 class="display-5 fw-bold text-dark">Welcome back, Admin!</h1>
        <p class="text-muted">Overview of your marketplace activities and community controls.</p>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- 1. Items Management -->
        <div class="col-md-6 col-lg-3">
            <div class="card admin-card shadow-sm p-3 h-100 border-top border-4 border-primary">
                <div class="card-body text-center d-flex flex-column">
                    <div class="icon-box bg-primary-soft">
                        <i class="bi bi-box-seam-fill fs-2"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Items</h4>
                    <p class="text-muted small mb-4 flex-grow-1">Monitor listings and maintain platform quality.</p>
                    <a asp-action="ManageItems" class="btn btn-primary btn-custom w-100 shadow-sm mt-auto">
                        <i class="bi bi-eye me-1"></i> Explore
                    </a>
                </div>
            </div>
        </div>

        <!-- 2. Users Control -->
        <div class="col-md-6 col-lg-3">
            <div class="card admin-card shadow-sm p-3 h-100 border-top border-4 border-success">
                <div class="card-body text-center d-flex flex-column">
                    <div class="icon-box bg-success-soft">
                        <i class="bi bi-people-fill fs-2"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Users</h4>
                    <p class="text-muted small mb-4 flex-grow-1">Manage community members and block accounts.</p>
                    <a asp-action="ManageUsers" class="btn btn-success btn-custom w-100 shadow-sm mt-auto">
                        <i class="bi bi-shield-check me-1"></i> Manage
                    </a>
                </div>
            </div>
        </div>

        <!-- 3. Reviews Management -->
        <div class="col-md-6 col-lg-3">
            <div class="card admin-card shadow-sm p-3 h-100 border-top border-4 border-warning">
                <div class="card-body text-center d-flex flex-column">
                    <div class="icon-box bg-warning-soft">
                        <i class="bi bi-star-fill fs-2"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Reviews</h4>
                    <p class="text-muted small mb-4 flex-grow-1">Moderate user feedback and remove bad reviews.</p>
                    <a asp-action="ManageReviews" class="btn btn-warning btn-custom w-100 shadow-sm mt-auto text-white">
                        <i class="bi bi-chat-left-quote-fill me-1"></i> Reviews
                    </a>
                </div>
            </div>
        </div>

        <!-- 4. Complaints -->
        <div class="col-md-6 col-lg-3">
            <div class="card admin-card shadow-sm p-3 h-100 border-top border-4 border-danger">
                <div class="card-body text-center d-flex flex-column">
                    <div class="icon-box bg-danger-soft">
                        <i class="bi bi-shield-exclamation-fill fs-2"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Complaints</h4>
                    <p class="text-muted small mb-4 flex-grow-1">Take action on user reports and safety flags.</p>
                    <a asp-controller="AdminComplaints" asp-action="Index" class="btn btn-danger btn-custom w-100 shadow-sm mt-auto">
                        <i class="bi bi-flag-fill me-1"></i> Reports
                        @await Component.InvokeAsync("AdminUnreadComplaints")
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>