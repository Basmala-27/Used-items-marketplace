@model IEnumerable<MarketplaceApp.Models.Category>

<section class="categories-section">
    <div class="container">
        <div class="section-header mb-5">
            <h2 class="fw-bold">Browse Categories</h2>
            <p class="text-muted">Explore items by category</p>
        </div>

        <div class="row g-4">
            @foreach (var cat in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="category-item-card">
                        <!-- منطقة الصورة والنص العلوي -->
                        <div class="category-img-box">
                            <img src="@cat.ImageUrl" alt="@cat.Name">
                            <div class="category-text-overlay">
                                <h4 class="mb-0">@cat.Name</h4>
                                <small>@cat.Items.Count items</small>
                            </div>
                        </div>

                        <!-- منطقة اللينك السفلي (الموشن) -->
                        <div class="category-link-footer">
                            <span>Browse @cat.Name</span>
                            <i class="bi bi-chevron-right"></i>
                        </div>

                        <!-- الرابط الذي يجعل الكارت بالكامل قابل للضغط -->
                        <a asp-controller="Items" asp-action="Category" asp-route-id="@cat.CategoryID" class="stretched-link"></a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>