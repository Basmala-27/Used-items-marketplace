@model MarketplaceApp.Models.RegisterVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <style>
        body {
            margin: 0;
            font-family: system-ui, sans-serif;
            background: #fff;
        }

        .main {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* LEFT */
        .left {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px;
        }

        .wrapper {
            width: 420px;
        }

        h2 {
            font-weight: 800;
            font-size: 30px;
        }

        .subtitle {
            font-size: 14px;
            color: #777;
            margin-bottom: 18px;
        }

        /* TRUST */
        .trust {
            background: linear-gradient(135deg,#fff7f3,#f7f7f7);
            padding: 14px;
            border-radius: 14px;
            display: flex;
            gap: 12px;
            font-size: 12px;
            color: #666;
            margin-bottom: 18px;
            align-items: center;
            box-shadow: 0 8px 20px rgba(0,0,0,0.04);
        }

            .trust i {
                font-size: 18px;
                color: #ff6b35;
            }

        /* INPUTS & VALIDATION */
        label {
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .form-control {
            border-radius: 10px;
            padding: 11px;
            font-size: 14px;
            transition: 0.2s;
        }

            .form-control:focus {
                border-color: #ff6b35;
                box-shadow: 0 0 0 0.2rem rgba(255,107,53,0.15);
            }

        /* Validation Styling */
        .input-validation-error {
            border-color: #dc3545 !important;
            background-color: #fff8f8;
        }

        .field-validation-error {
            color: #dc3545;
            font-size: 11px;
            font-weight: 500;
            display: block;
            margin-top: 2px;
            margin-bottom: 8px;
        }

        /* BUTTON */
        .btn-orange {
            background: #ff6b35;
            color: white;
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: none;
            font-weight: 600;
            margin-top: 12px;
            transition: 0.2s;
        }

            .btn-orange:hover {
                background: #ff5a1f;
                transform: translateY(-1px);
            }

        /* SOCIAL */
        .social {
            display: flex;
            gap: 10px;
        }

            .social a {
                flex: 1;
                border: 1px solid #eee;
                border-radius: 10px;
                padding: 9px;
                text-align: center;
                font-size: 13px;
                text-decoration: none;
                color: #333;
                transition: 0.2s;
            }

                .social a:hover {
                    background: #fafafa;
                    transform: translateY(-1px);
                }

        /* RIGHT (UNCHANGED) */
        .right {
            flex: 1;
            background: radial-gradient(circle at top right, #ffe7df, #fff);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        @@keyframes float {
            0%

        {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-18px);
        }

        100% {
            transform: translateY(0px);
        }

        }

        .icon {
            position: absolute;
            background: white;
            border-radius: 14px;
            width: 52px;
            height: 52px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.06);
            animation: float 4s ease-in-out infinite;
        }

            .icon.main {
                background: #ff6b35;
                color: white;
                width: 70px;
                height: 70px;
                font-size: 22px;
                top: 22%;
            }

        .i1 {
            top: 16%;
            right: 32%;
            animation-delay: 0s;
        }

        .i2 {
            top: 16%;
            right: 60%;
            animation-delay: 0.8s;
        }

        .i3 {
            top: 30%;
            right: 60%;
            animation-delay: 1.5s;
        }

        .i4 {
            top: 30%;
            right: 32%;
            animation-delay: 2s;
        }

        .box {
            width: 380px;
            margin-top: 160px;
        }

        .feature {
            background: white;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 10px;
            display: flex;
            gap: 10px;
            font-size: 13px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.04);
            transition: 0.2s;
        }

            .feature:hover {
                transform: translateX(5px);
            }

            .feature i {
                color: #ff6b35;
                font-size: 18px;
            }

    </style>
</head>

<body>

    <div class="main">

        <!-- LEFT (WITH VALIDATION) -->
        <div class="left">
            <div class="wrapper">

                <h2>Join the marketplace</h2>
                <p class="subtitle">Create an account to start buying and selling items safely</p>

                <div class="trust">
                    <i class="bi bi-shield-check"></i>
                    <div>
                        Join thousands of verified users<br />
                        Secure & trusted marketplace
                    </div>
                </div>

                <form asp-action="Register" method="post" enctype="multipart/form-data">
                    <!-- Validation Summary (Optional but helpful) -->
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                    <label asp-for="Name">Full Name</label>
                    <input asp-for="Name" class="form-control" placeholder="John Doe" />
                    <span asp-validation-for="Name" class="text-danger"></span>

                    <label asp-for="Email" class="mt-2">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="example@mail.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>

                    <label asp-for="PhoneNumber" class="mt-2">Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="01xxxxxxxxx" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>

                    <label class="mt-2">Profile Picture (Optional)</label>
                    <input name="ProfileImageFile" type="file" class="form-control mb-1" accept="image/*" />

                    <div class="row mt-2">
                        <div class="col">
                            <label asp-for="Password">Password</label>
                            <input asp-for="Password" type="password" class="form-control" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="col">
                            <label asp-for="ConfirmPassword">Confirm</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <button type="submit" class="btn-orange">Create Account</button>

                    <div class="text-center mt-3 mb-2" style="font-size:12px;color:#777;">
                        Or continue with
                    </div>

                    <div class="social">
                        <a href="#"><i class="bi bi-google"></i> Google</a>
                        <a href="#"><i class="bi bi-facebook text-primary"></i> Facebook</a>
                    </div>

                    <p class="text-center mt-3" style="font-size:12px;">
                        Already have account?
                        <a href="/Account/Login" style="color:#ff6b35;text-decoration:none;">Sign in</a>
                    </p>

                </form>

            </div>
        </div>

        <!-- RIGHT (UNCHANGED AS REQUESTED) -->
        <div class="right">

            <div class="icon i1"><i class="bi bi-bag"></i></div>
            <div class="icon i2"><i class="bi bi-graph-up"></i></div>
            <div class="icon main"><i class="bi bi-chat"></i></div>
            <div class="icon i3"><i class="bi bi-lock"></i></div>
            <div class="icon i4"><i class="bi bi-cart"></i></div>

            <div class="box">
                <h5 class="fw-bold text-center">Why join our marketplace?</h5>

                <div class="feature">
                    <i class="bi bi-patch-check-fill"></i>
                    <div><b>Secure Transactions</b><br />Protected payments</div>
                </div>

                <div class="feature">
                    <i class="bi bi-chat-left-text-fill"></i>
                    <div><b>Direct Messaging</b><br />Safe buyer-seller chat</div>
                </div>

                <div class="feature">
                    <i class="bi bi-star-fill"></i>
                    <div><b>Verified Ratings</b><br />Trusted reviews system</div>
                </div>

                <div class="feature">
                    <i class="bi bi-list-check"></i>
                    <div><b>Easy Listing</b><br />List items in minutes</div>
                </div>

            </div>

        </div>

    </div>

    <!-- Scripts for Instant Validation -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>