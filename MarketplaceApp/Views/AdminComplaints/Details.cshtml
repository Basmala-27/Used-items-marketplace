@model MarketplaceApp.ViewModels.AdminComplaintDetailsVM
@using MarketplaceApp.Models

@{
    ViewData["Title"] = "Complaint Details";
    Layout = "_AdminLayout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-block">
                <i class="bi bi-arrow-left"></i> Back to Complaints
            </a>
            <h2 class="fw-bold mb-0">Complaint #@Model.Complaint.Id</h2>
        </div>
        
        <form asp-action="UpdateStatus" method="post" class="d-flex gap-2 align-items-center">
            <input type="hidden" name="id" value="@Model.Complaint.Id" />
            <label class="fw-bold mb-0">Change Status:</label>
            <select name="status" class="form-select form-select-sm w-auto d-inline-block" onchange="this.form.submit()">
                @foreach (var status in Enum.GetValues(typeof(ComplaintStatus)))
                {
                    if ((ComplaintStatus)status == Model.Complaint.Status)
                    {
                        <option value="@status" selected>@status</option>
                    }
                    else
                    {
                        <option value="@status">@status</option>
                    }
                }
            </select>
        </form>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Main Details -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h4 class="fw-bold mb-0">@Model.Complaint.Title</h4>
                        @{
                            var badgeClass = Model.Complaint.Status switch
                            {
                                ComplaintStatus.Pending => "bg-warning text-dark",
                                ComplaintStatus.UnderReview => "bg-info text-white",
                                ComplaintStatus.Resolved => "bg-success",
                                ComplaintStatus.Dismissed => "bg-secondary",
                                _ => "bg-primary"
                            };
                        }
                        <span class="badge rounded-pill @badgeClass fs-6 px-3">@Model.Complaint.Status</span>
                    </div>
                    
                    <p class="text-muted small mb-4">
                        <i class="bi bi-calendar3"></i> Submitted on @Model.Complaint.CreatedAt.ToString("MMMM dd, yyyy 'at' hh:mm tt")
                    </p>

                    <div class="bg-light p-4 rounded-4 mb-0">
                        <h6 class="fw-bold text-muted mb-2">Description</h6>
                        <p class="mb-0" style="white-space: pre-wrap; line-height: 1.6;">@Model.Complaint.Description</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Involved Parties & Quick Actions -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="fw-bold"><i class="bi bi-people-fill me-2 text-primary"></i> Involved Parties</h5>
                </div>
                <div class="card-body">
                    
                    <!-- Complainant -->
                    <div class="mb-4">
                        <label class="text-muted small fw-bold text-uppercase">Complainant</label>
                        <div class="d-flex align-items-center mt-2">
                            <i class="bi bi-person-circle fs-3 text-secondary me-2"></i>
                            <div>
                                <h6 class="mb-0 fw-bold">@Model.Complainant.Name</h6>
                                <small class="text-muted">@Model.Complainant.Email</small>
                            </div>
                        </div>
                    </div>

                    <hr class="text-muted" />

                    <!-- Target User -->
                    @if (Model.TargetUser != null)
                    {
                        <div class="mb-4">
                            <label class="text-muted small fw-bold text-uppercase text-danger">Reported User</label>
                            <div class="d-flex align-items-center mt-2">
                                <i class="bi bi-person-exclamation fs-3 text-danger me-2"></i>
                                <div>
                                    <h6 class="mb-0 fw-bold">
                                        <a asp-controller="Profile" asp-action="SellerProfile" asp-route-id="@Model.TargetUser.Id" class="text-dark text-decoration-none" target="_blank">
                                            @Model.TargetUser.Name
                                            <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                        </a>
                                    </h6>
                                    @if (Model.TargetUser.IsBlocked)
                                    {
                                        <span class="badge bg-danger mt-1">Banned</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Target Item -->
                    @if (Model.TargetItem != null)
                    {
                        <div class="mb-2">
                            <label class="text-muted small fw-bold text-uppercase text-danger">Reported Item</label>
                            <div class="d-flex align-items-center mt-2">
                                <i class="bi bi-box-seam fs-3 text-danger me-2"></i>
                                <div>
                                    <h6 class="mb-0 fw-bold">
                                        <a asp-controller="Items" asp-action="Details" asp-route-id="@Model.TargetItem.ItemID" class="text-dark text-decoration-none" target="_blank">
                                            @Model.TargetItem.Title
                                            <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                                        </a>
                                    </h6>
                                </div>
                            </div>
                        </div>
                    }
                    
                    @if(Model.TargetUser == null && Model.TargetItem == null)
                    {
                        <p class="text-muted small fst-italic">No specific user or item was targeted.</p>
                    }

                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card border-0 shadow-sm rounded-4 border-top border-4 border-danger">
                <div class="card-body">
                    <h5 class="fw-bold mb-3"><i class="bi bi-lightning-charge-fill text-warning me-2"></i> Quick Actions</h5>
                    
                    <div class="d-grid gap-2">
                        @if (Model.Complaint.Status != ComplaintStatus.Dismissed)
                        {
                            <form asp-action="Dismiss" method="post">
                                <input type="hidden" name="id" value="@Model.Complaint.Id" />
                                <button type="submit" class="btn btn-outline-secondary w-100 rounded-pill text-start" onclick="return confirm('Are you sure you want to dismiss this complaint?')">
                                    <i class="bi bi-x-circle me-2"></i> Dismiss Complaint
                                </button>
                            </form>
                        }

                        @if (Model.TargetUser != null)
                        {
                            <form asp-action="WarnUser" method="post">
                                <input type="hidden" name="id" value="@Model.Complaint.Id" />
                                <button type="submit" class="btn btn-outline-warning text-dark w-100 rounded-pill text-start" onclick="return confirm('Send a warning to @Model.TargetUser.Name?')">
                                    <i class="bi bi-exclamation-triangle me-2"></i> Warn User
                                </button>
                            </form>

                            @if (!Model.TargetUser.IsBlocked)
                            {
                                <form asp-action="BanUser" method="post">
                                    <input type="hidden" name="id" value="@Model.Complaint.Id" />
                                    <button type="submit" class="btn btn-outline-danger w-100 rounded-pill text-start" onclick="return confirm('WARNING: Are you sure you want to completely ban @Model.TargetUser.Name?')">
                                        <i class="bi bi-person-x-fill me-2"></i> Ban User
                                    </button>
                                </form>
                            }
                        }

                        @if (Model.TargetItem != null)
                        {
                            <form asp-action="DeleteItem" method="post">
                                <input type="hidden" name="id" value="@Model.Complaint.Id" />
                                <button type="submit" class="btn btn-danger w-100 rounded-pill text-start" onclick="return confirm('WARNING: This will permanently delete the item. Continue?')">
                                    <i class="bi bi-trash3-fill me-2"></i> Delete Item
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
