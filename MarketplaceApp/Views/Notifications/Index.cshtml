@model List<MarketplaceApp.Models.Notification>

@{
    ViewData["Title"] = "إشعاراتي";
}

<div class="container mt-4">
    <h3>إشعاراتك 🔔</h3>
    <hr />
    @if (!Model.Any())
    {
        <p class="alert alert-light">لا توجد إشعارات جديدة.</p>
    }
    else
    {
        <div class="list-group">
            @foreach (var n in Model)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center @(n.IsRead ? "" : "bg-light fw-bold")">
                    <a href="@n.TargetUrl" class="text-decoration-none text-dark">
                        @n.MessageText <br />
                        <small class="text-muted">@n.CreatedAt.ToString("g")</small>
                    </a>
                    @if (!n.IsRead)
                    {
                        <form asp-action="MarkAsRead" asp-route-id="@n.NotificationID" method="post">
                            <button type="submit" class="btn btn-sm btn-outline-primary">تمت القراءة</button>
                        </form>
                    }
                </div>
            }
        </div>
    }
</div>