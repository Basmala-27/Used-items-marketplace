@model Item
@using System.Security.Claims
@using MarketplaceApp.Enums

@{
    ViewData["Title"] = "Details - " + Model.Title;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var walletBalance = (decimal)(ViewBag.WalletBalance ?? 0m);
    var hasEnoughBalance = walletBalance >= Model.Price;

    var isOwner = Model.UserID != null && Model.UserID == currentUserId;
    var isAvailable = Model.Status == ItemStatus.Available;
}

<div class="container py-5">
    <div class="row g-5">
        <!-- Left Column: Images & Seller Info -->
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                @if (Model.Images != null && Model.Images.Any())
                {
                    <div id="itemCarousel" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            @for (int i = 0; i < Model.Images.Count; i++)
                            {
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <img src="@Model.Images.ElementAt(i).ImageUrl" class="d-block w-100" style="height: 450px; object-fit: cover;" alt="@Model.Title">
                                </div>
                            }
                        </div>
                        @if (Model.Images.Count > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#itemCarousel" data-bs-slide="prev"><span class="carousel-control-prev-icon"></span></button>
                            <button class="carousel-control-next" type="button" data-bs-target="#itemCarousel" data-bs-slide="next"><span class="carousel-control-next-icon"></span></button>
                        }
                    </div>
                }
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 450px;">
                        <span class="text-muted">No Image Available</span>
                    </div>
                }
            </div>

            <!-- Seller Info -->
            <div class="mt-3 px-2">
                <div class="d-flex justify-content-between small text-muted align-items-center">
                    <div class="d-flex flex-column">
                        <a asp-controller="Profile" asp-action="SellerProfile" asp-route-id="@Model.UserID"
                           class="text-decoration-none text-dark fw-bold mb-1 seller-link-container">
                            <i class="bi bi-person-circle fs-5 me-1 align-middle text-orange"></i>
                            <span class="align-middle seller-link-hover">Seller: @(Model.User?.Name ?? "User")</span>
                        </a>

                        <!-- Dynamic Star Rating -->
                        <div class="d-flex align-items-center gap-1">
                            @{
                                double trustScore = Model.User?.TrustScore ?? 0.0;
                                int reviewCount = Model.User?.Rating ?? 0;
                            }
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= trustScore)
                                {
                                    <i class="bi bi-star-fill text-warning" style="font-size: 0.85rem;"></i>
                                }
                                else if (i - trustScore <= 0.5)
                                {

                                    <i class="bi bi-star-half text-warning" style="font-size: 0.85rem;"></i>
                                }
                                else
                                {

                                    <i class="bi bi-star text-muted opacity-50" style="font-size: 0.85rem;"></i>
                                }
                            }
                            <span class="ms-1 text-muted" style="font-size: 0.75rem;">(@reviewCount reviews)</span>
                        </div>
                    </div>
                    <span><i class="bi bi-clock me-1"></i>Posted: @Model.CreatedAt.ToString("dd MMM yyyy")</span>
                </div>
            </div>
        </div>

        <!-- Right Column: Details & Actions -->
        <div class="col-md-6">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a asp-action="Index" class="text-orange text-decoration-none">Marketplace</a></li>
                        <li class="breadcrumb-item active">@Model.Category?.Name</li>
                    </ol>
                </nav>
                @{
                    var statusBadgeClass = Model.Status switch
                    {
                        ItemStatus.Available => "bg-success-subtle text-success border-success",
                        ItemStatus.PendingDelivery => "bg-warning-subtle text-warning border-warning",
                        ItemStatus.Sold => "bg-danger-subtle text-danger border-danger",
                        _ => "bg-secondary-subtle text-secondary"
                    };
                }
                <span class="badge px-3 py-2 border rounded-pill @statusBadgeClass">@Model.Status.ToString()</span>
            </div>

            <h1 class="display-6 fw-bold text-dark mb-2">@Model.Title</h1>

            <div class="d-flex align-items-center gap-3 mb-4">
                <h2 class="text-orange fw-bold mb-0">$@Model.Price.ToString("0.00")</h2>
                @if (Model.IsAvailableForSale)
                {
                    <span class="badge bg-orange-light text-orange px-3 py-2 border border-orange rounded-pill small">
                        <i class="bi bi-chat-quote-fill me-1"></i> Open for Negotiation
                    </span>
                }
            </div>

            <div class="card bg-light border-0 rounded-4 mb-4 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold mb-2 text-dark">Description</h6>
                    <p class="text-muted mb-0" style="line-height: 1.6;">@Model.Description</p>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-6">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-geo-alt text-orange fs-5"></i>
                        <div>
                            <small class="d-block text-muted">Location</small>
                            <span class="fw-bold">@Model.Location</span>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-calendar-check text-orange fs-5"></i>
                        <div>
                            <small class="d-block text-muted">Condition</small>
                            <span class="fw-bold">@Model.Condition</span>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="mb-4">

            <!-- Buttons -->
            <div class="d-flex flex-wrap gap-2">
                @if (User.Identity!.IsAuthenticated)
                {
                    if (!isOwner)
                    {
                        if (isAvailable)
                        {
                            <a asp-controller="Chat" asp-action="StartConversation" asp-route-itemId="@Model.ItemID"
                               class="btn btn-orange btn-lg px-4 shadow-sm text-white fw-bold" style="border-radius: 50px; flex: 1;">
                                <i class="bi bi-chat-dots me-2"></i> Chat
                            </a>

                            <button type="button" id="buyNowBtn" class="btn btn-buy btn-lg px-4 fw-bold shadow-sm"
                                    data-bs-toggle="modal" data-bs-target="#buyConfirmModal" style="border-radius: 50px; flex: 1;">
                                <i class="bi bi-bag-check-fill me-2"></i> Buy Now
                            </button>

                            @if (Model.IsAvailableForSwap)
                            {
                                <a asp-controller="Items" asp-action="CreateSwap" asp-route-targetItemId="@Model.ItemID"
                                   class="btn btn-warning btn-lg px-4 shadow-sm text-dark fw-bold w-100 mt-2" style="border-radius: 50px;">
                                    <i class="bi bi-arrow-left-right me-2"></i> Request Swap
                                </a>
                            }

                            <div class="w-100 text-center mt-3">
                                <a asp-controller="Complaints" asp-action="Create" asp-route-targetItemId="@Model.ItemID" class="text-danger text-decoration-none small">
                                    <i class="bi bi-flag-fill me-1"></i> Report Item
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-secondary w-100 rounded-3 text-center">
                                <i class="bi bi-info-circle me-2"></i> This item is currently @Model.Status.
                            </div>
                        }
                    }
                    else
                    {
                        <a asp-action="Edit" asp-route-id="@Model.ItemID" class="btn btn-light border px-4 flex-grow-1" style="border-radius:50px;">
                            <i class="bi bi-pencil me-2"></i> Edit My Item
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.ItemID" class="btn btn-outline-danger px-4" style="border-radius:50px;">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    }
                }
                else
                {
                    <div class="alert alert-warning w-100 rounded-3">
                        <i class="bi bi-lock-fill me-2"></i> Please <a asp-area="Identity" asp-page="/Account/Login" class="fw-bold text-dark">Login</a> to interact.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Buy Modal -->
@if (User.Identity!.IsAuthenticated && !isOwner && isAvailable)
{
    <div class="modal fade" id="buyConfirmModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4 border-0 shadow-lg overflow-hidden">
                <div class="modal-header border-0 pb-0" style="background: linear-gradient(135deg, #f97316, #fb923c);">
                    <div class="d-flex align-items-center gap-3 py-2 text-white">
                        <div class="modal-icon-circle"><i class="bi bi-bag-check-fill fs-4"></i></div>
                        <div>
                            <h5 class="modal-title fw-bold mb-0">Confirm Purchase</h5>
                            <small class="opacity-75">Secure Escrow System</small>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="product-summary-card mb-4">
                        <div class="d-flex gap-3 align-items-center">
                            <img src="@(Model.Images?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png")" class="product-thumb rounded-3">
                            <div>
                                <h6 class="fw-bold mb-1">@Model.Title</h6>
                                <div class="price-tag">$@Model.Price.ToString("0.00")</div>
                            </div>
                        </div>
                    </div>

                    <div class="wallet-info-card mb-3 @(hasEnoughBalance ? "wallet-ok" : "wallet-low")">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <small class="d-block opacity-75">Your Balance</small>
                                <strong class="fs-5">$@walletBalance.ToString("0.00")</strong>
                            </div>
                            <div class="text-end">
                                <small class="d-block opacity-75">After Purchase</small>
                                @if (hasEnoughBalance)
                                {
                                    <strong class="text-success">$@((walletBalance - Model.Price).ToString("0.00"))</strong>
                                }
                                else
                                {

                                    <strong class="text-danger">Insufficient</strong>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="escrow-steps">
                        <div class="escrow-step"><div class="step-num">1</div><div>Payment is held securely in Escrow</div></div>
                        <div class="escrow-step"><div class="step-num">2</div><div>Seller ships the item to you</div></div>
                        <div class="escrow-step"><div class="step-num">3</div><div>Confirm receipt to release funds</div></div>
                    </div>
                </div>

                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light flex-grow-1 rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    @if (hasEnoughBalance)
                    {
                        <button type="button" id="confirmBuyBtn" class="btn btn-buy flex-grow-1 rounded-pill fw-bold" data-item-id="@Model.ItemID">Confirm Buy</button>
                    }
                    else
                    {
                        <a asp-controller="Transactions" asp-action="TopUp" class="btn btn-orange flex-grow-1 rounded-pill fw-bold text-white">Top Up Wallet</a>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Toast -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 9999;">
    <div id="buyToast" class="toast align-items-center border-0 rounded-4 shadow-lg" role="alert">
        <div class="d-flex">
            <div class="toast-body fw-semibold" id="buyToastMsg"></div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<style>
    .text-orange {
        color: #FF8C00 !important;
    }

    .bg-orange-light {
        background-color: #fff5e6 !important;
    }

    .border-orange {
        border-color: #FF8C00 !important;
    }

    .btn-orange {
        background-color: #FF8C00;
        color: white;
        border: none;
        transition: 0.3s;
    }

        .btn-orange:hover {
            background-color: #e67e00;
            color: white;
            transform: translateY(-2px);
        }

    .btn-buy {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        border: none;
        transition: 0.3s;
    }

        .btn-buy:hover {
            background: linear-gradient(135deg, #059669, #047857);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(16,185,129,0.4);
        }

    .rounded-4 {
        border-radius: 1.25rem !important;
    }

    .seller-link-hover:hover {
        color: #FF8C00;
    }

    .modal-icon-circle {
        width: 40px;
        height: 40px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-summary-card {
        background: #f8fafc;
        border-radius: 12px;
        padding: 15px;
        border: 1px solid #e2e8f0;
    }

    .product-thumb {
        width: 60px;
        height: 60px;
        object-fit: cover;
    }

    .price-tag {
        font-weight: 800;
        color: #f97316;
        font-size: 1.2rem;
    }

    .wallet-info-card {
        border-radius: 12px;
        padding: 15px;
        border: 2px solid;
    }

    .wallet-ok {
        background: #f0fdf4;
        border-color: #22c55e;
        color: #166534;
    }

    .wallet-low {
        background: #fef2f2;
        border-color: #ef4444;
        color: #991b1b;
    }

    .escrow-steps {
        background: #f8fafc;
        border-radius: 12px;
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        font-size: 0.85rem;
    }

    .escrow-step {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .step-num {
        width: 22px;
        height: 22px;
        background: #f97316;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.75rem;
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const confirmBtn = document.getElementById('confirmBuyBtn');
            if (confirmBtn) {
                confirmBtn.addEventListener('click', function () {
                    const itemId = this.dataset.itemId;
                    const btn = this;
                    btn.disabled = true;
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';

                    const formData = new FormData();
                    formData.append('itemId', itemId);
                    formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                    fetch('/Transactions/BuyItem', {
                        method: 'POST',
                        body: formData,
                        credentials: 'same-origin'
                    })
                    .then(r => r.json())
                    .then(data => {
                        const modal = bootstrap.Modal.getInstance(document.getElementById('buyConfirmModal'));
                        if (modal) modal.hide();

                        showToast(data.message, data.success ? 'success' : 'danger');
                        if (data.success) setTimeout(() => location.reload(), 2000);
                        else {
                            btn.disabled = false;
                            btn.innerHTML = 'Confirm Buy';
                        }
                    })
                    .catch(() => {
                        showToast('Error connecting to server.', 'danger');
                        btn.disabled = false;
                        btn.innerHTML = 'Confirm Buy';
                    });
                });
            }

            function showToast(message, type) {
                const toast = document.getElementById('buyToast');
                const toastMsg = document.getElementById('buyToastMsg');
                toast.className = `toast align-items-center border-0 rounded-4 shadow-lg text-bg-${type}`;
                toastMsg.textContent = message;
                new bootstrap.Toast(toast, { delay: 4000 }).show();
            }
        });
    </script>
}