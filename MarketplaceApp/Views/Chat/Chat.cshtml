@model List<Message>
@using System.Security.Claims
@{
    var convo = ViewBag.Conversation as Conversation;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var otherUser = convo?.BuyerID == currentUserId ? convo?.Seller : convo?.Buyer;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="chat-main-wrapper">
    <header class="chat-header">
        <div class="header-info">
            <div class="user-meta">
                <!-- صورة المستخدم مع منطق الصورة الافتراضية -->
                @if (otherUser != null && !string.IsNullOrEmpty(otherUser.ProfileImage))
                {
                    <img src="@otherUser.ProfileImage" class="header-avatar" alt="@otherUser.Name" />
                }
                else
                {
                    <img src="~/images/default-avatar.png" class="header-avatar" alt="Default User" />
                }
                <div class="text-meta">
                    <h6>@(otherUser?.Name ?? "User")</h6>
                    <small>Discussion about @convo?.Item?.Title</small>
                </div>
            </div>
        </div>
    </header>

    <div id="chatBox" class="messages-container">
        @foreach (var msg in Model)
        {
            var isMine = msg.SenderID == currentUserId;
            <div class="message-row @(isMine ? "outgoing" : "incoming")">
                <div class="bubble">
                    @msg.MessageText
                    <span class="time">@msg.CreatedAt.ToString("h:mm tt")</span>
                </div>
            </div>
        }
    </div>

    <footer class="chat-footer">
        <form asp-action="SendMessage" method="post" class="modern-input-area">
            <input type="hidden" name="conversationId" value="@convo?.ConversationID" />
            <input type="text" name="content" class="chat-input" placeholder="Type a message..." required autocomplete="off" />
            <button type="submit" class="send-arrow-btn">
                <i class="fa-solid fa-paper-plane"></i>
            </button>
        </form>
    </footer>
</div>

<style>
    :root {
        --primary-orange: #FF6B00;
        --light-gray: #f8f9fa;
    }

    .chat-main-wrapper {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 70px);
        background: #fff;
    }

    .chat-header {
        padding: 10px 20px;
        border-bottom: 1px solid #eee;
    }

    .user-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        justify-content: center;
    }

    .header-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #eee;
    }

    .text-meta h6 {
        margin: 0;
        font-weight: bold;
        color: #333;
    }

    .text-meta small {
        color: #888;
        font-size: 11px;
    }

    .messages-container {
        flex: 1;
        padding: 20px;
        overflow-y: auto;
        background: #fff;
    }

    .message-row {
        display: flex;
        margin-bottom: 12px;
        width: 100%;
    }

    .incoming {
        justify-content: flex-start;
    }

    .outgoing {
        justify-content: flex-end;
    }

    .bubble {
        max-width: 75%;
        padding: 10px 15px;
        border-radius: 18px;
        font-size: 14px;
        position: relative;
    }

    .incoming .bubble {
        background: var(--light-gray);
        color: #333;
        border-bottom-left-radius: 4px;
    }

    .outgoing .bubble {
        background: var(--primary-orange);
        color: #fff;
        border-bottom-right-radius: 4px;
    }

    .time {
        display: block;
        font-size: 9px;
        margin-top: 4px;
        opacity: 0.7;
        text-align: right;
    }

    .chat-footer {
        padding: 15px;
        border-top: 1px solid #eee;
    }

    .modern-input-area {
        display: flex;
        align-items: center;
        background: var(--light-gray);
        border-radius: 25px;
        padding: 5px 15px;
    }

    .chat-input {
        flex: 1;
        border: none;
        background: transparent;
        padding: 10px;
        outline: none;
        font-size: 14px;
    }

    .send-arrow-btn {
        background: transparent !important;
        border: none !important;
        color: var(--primary-orange) !important;
        font-size: 22px;
        cursor: pointer;
        display: flex;
        align-items: center;
        min-width: 40px;
        justify-content: center;
        transition: 0.2s;
    }

        .send-arrow-btn:hover {
            transform: scale(1.1) translateX(2px);
        }
</style>