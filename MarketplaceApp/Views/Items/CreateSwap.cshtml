@model CreateSwapViewModel
@{
    ViewData["Title"] = "Create Swap Request";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <!-- Header Section -->
            <div class="text-center mb-5">
                <h2 class="fw-bold text-dark">Confirm Swap Deal</h2>
                <p class="text-muted">Exchange your item with another one within a similar price range</p>
            </div>

            @if (ViewBag.ValidationErrors != null)
            {
                <div class="alert alert-danger rounded-3 border-0 shadow-sm mb-4">
                    <ul class="mb-0">
                        @foreach (var error in ViewBag.ValidationErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="CreateSwap" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="RequestedItemId" />
                <input type="hidden" asp-for="RequestedItemName" value="@Model.RequestedItemName" />

                <div class="row align-items-stretch g-4">

                    <!-- Requested Item Card -->
                    <div class="col-md-5">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden shadow-hover">
                            <div class="bg-light p-3 text-center border-bottom">
                                <span class="badge bg-secondary mb-2 px-3">Requested Item</span>
                                <h5 class="mb-0 text-truncate fw-bold">@Model.RequestedItemName</h5>
                            </div>
                            <div class="card-body text-center d-flex flex-column justify-content-center py-5">
                                <div class="price-circle mx-auto mb-3">
                                    <span class="fs-3 fw-bold text-dark">$@Model.RequestedItemPrice</span>
                                </div>
                                <p class="small text-muted mb-0">Owned by the other party</p>
                            </div>
                        </div>
                    </div>

                    <!-- Visual Divider (The Swap Icon) -->
                    <div class="col-md-2 d-flex align-items-center justify-content-center">
                        <div class="swap-divider shadow-sm bg-white border border-orange">
                            <i class="bi bi-arrow-left-right fs-2 text-orange"></i>
                        </div>
                    </div>

                    <!-- Offered Item Card (Your Choice) -->
                    <div class="col-md-5">
                        <div class="card h-100 border-orange-focus shadow-sm rounded-4 overflow-hidden shadow-hover">
                            <div class="bg-orange-light p-3 text-center border-bottom border-orange-subtle">
                                <span class="badge bg-orange mb-2 px-3">Your Offering</span>
                                <h5 class="mb-0 fw-bold">Select Your Item</h5>
                            </div>
                            <div class="card-body py-5 px-4">
                                <div class="form-group mb-0">
                                    <label class="form-label small fw-bold text-muted text-uppercase mb-2">My Available Items</label>
                                    <select asp-for="OfferedItemId" class="form-select form-select-lg border-orange shadow-none" required>
                                        <option value="">-- Choose your item --</option>
                                        @if (Model.MyAvailableItems != null)
                                        {
                                            @foreach (var item in Model.MyAvailableItems)
                                            {
                                                <option value="@item.ItemID">@item.Title ($@item.Price)</option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="OfferedItemId" class="text-danger small mt-2 d-block"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Footer Info & Actions -->
                <div class="mt-5 text-center">
                    <div class="bg-light p-3 rounded-3 d-inline-block border mb-4">
                        <i class="bi bi-info-circle text-orange me-2"></i>
                        <span class="text-muted small">Only items priced between <strong>$@ViewBag.MinAllowedPrice</strong> and <strong>$@ViewBag.MaxAllowedPrice</strong> are eligible.</span>
                    </div>

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Items" asp-action="Details" asp-route-id="@Model.RequestedItemId" class="btn btn-lg btn-light border px-4 rounded-pill fw-bold text-muted">Cancel</a>
                        <button type="submit" class="btn btn-lg btn-orange px-5 rounded-pill shadow-sm fw-bold">Send Request</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    :root {
        --theme-orange: #FF8C00; /* مأخوذ من الثيم في صورة image_6a5723.jpg */
        --theme-orange-light: #FFF5E6;
    }

    .text-orange {
        color: var(--theme-orange) !important;
    }

    .bg-orange {
        background-color: var(--theme-orange) !important;
        color: white;
    }

    .bg-orange-light {
        background-color: var(--theme-orange-light) !important;
    }

    .border-orange {
        border-color: var(--theme-orange) !important;
    }

    .btn-orange {
        background-color: var(--theme-orange);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-orange:hover {
            background-color: #e67e00;
            color: white;
            transform: translateY(-2px);
        }

    .border-orange-focus {
        border: 2px solid var(--theme-orange) !important;
    }

    .rounded-4 {
        border-radius: 1.25rem !important;
    }

    .swap-divider {
        width: 65px;
        height: 65px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        z-index: 2;
    }

    .price-circle {
        width: 100px;
        height: 100px;
        background: #f8f9fa;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px dashed #ddd;
    }

    .shadow-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .shadow-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,0.1) !important;
        }

    .form-select-lg {
        font-size: 1rem;
        padding-top: 0.75rem;
        padding-bottom: 0.75rem;
    }
</style>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">