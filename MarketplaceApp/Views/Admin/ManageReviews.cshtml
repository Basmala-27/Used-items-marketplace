@using System.Text.Encodings.Web
@model IEnumerable<MarketplaceApp.Models.Review>
@{
    ViewData["Title"] = "Manage Reviews";
    Layout = "_AdminLayout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<style>
    .table-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .rating-stars {
        color: #ffc107;
        font-size: 0.9rem;
    }

    .review-comment-preview {
        max-width: 200px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        cursor: pointer;
    }

        .review-comment-preview:hover {
            text-decoration: underline;
            color: #0d6efd !important;
        }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">Reviews Management</h2>
            <p class="text-muted">Monitor and moderate user feedback across the platform.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i> Dashboard
        </a>
    </div>

    <div class="card table-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted uppercase">
                    <tr>
                        <th class="ps-4 py-3">Reviewer</th>
                        <th class="py-3">Seller</th>
                        <th class="py-3">Rating</th>
                        <th class="py-3">Comment</th>
                        <th class="py-3">Date</th>
                        <th class="text-end pe-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">No reviews found in the database.</td>
                        </tr>
                    }
                    @foreach (var review in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-semibold">@(review.Reviewer?.UserName ?? "N/A")</span>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark">@(review.Seller?.UserName ?? "N/A")</span>
                            </td>
                            <td>
                                <div class="rating-stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star text-muted opacity-50")"></i>
                                    }
                                </div>
                            </td>
                            <td>
                                <p class="review-comment-preview mb-0 small text-muted"
                                   onclick="viewComment('@(review.Reviewer?.UserName)', '@review.Rating', '@JavaScriptEncoder.Default.Encode(review.Comment)')">
                                    @review.Comment
                                </p>
                            </td>
                            <td>
                                <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                            </td>
                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-sm btn-light rounded-pill px-3 me-1"
                                        onclick="viewComment('@(review.Reviewer?.UserName)', '@review.Rating', '@JavaScriptEncoder.Default.Encode(review.Comment)')">
                                    <i class="bi bi-eye me-1"></i> View
                                </button>

                                <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                        onclick="confirmDelete('@review.ReviewID')">
                                    <i class="bi bi-trash me-1"></i> Delete
                                </button>

                                <form id="delete-form-@review.ReviewID" asp-action="DeleteReview" asp-route-id="@review.ReviewID" method="post" style="display:none;">
                                    @Html.AntiForgeryToken()
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Review Modal -->
<div class="modal fade" id="reviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="modalReviewerName">Review Detail</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
                <div id="modalRatingStars" class="rating-stars mb-2 fs-5"></div>
                <div class="p-3 bg-light rounded-3">
                    <p id="modalFullComment" class="mb-0 text-dark" style="white-space: pre-wrap;"></p>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@section Scripts {
    <script>
        function viewComment(user, rating, comment) {
            document.getElementById('modalReviewerName').innerText = "Review by " + user;
            document.getElementById('modalFullComment').innerText = comment;

            let starsHtml = '';
            for (let i = 1; i <= 5; i++) {
                starsHtml += `<i class="bi ${i <= rating ? 'bi-star-fill text-warning' : 'bi-star text-muted opacity-50'}"></i> `;
            }
            document.getElementById('modalRatingStars').innerHTML = starsHtml;

            var myModal = new bootstrap.Modal(document.getElementById('reviewModal'));
            myModal.show();
        }

        function confirmDelete(id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "This review will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('delete-form-' + id).submit();
                }
            })
        }

        @if (TempData["Success"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Success!',
                    text: '@TempData["Success"]',
                    timer: 2500,
                    showConfirmButton: false
                });
                </text>
        }
    </script>
}