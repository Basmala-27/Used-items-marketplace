@{
    ViewData["Title"] = "Item Unavailable";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="text-center p-5 rounded-4 shadow-lg bg-white" style="max-width: 500px;">
        <div class="mb-4 text-warning">
            <i class="bi bi-lock-fill" style="font-size: 5rem;"></i>
        </div>
        <h2 class="fw-bold mb-3">Item Unavailable</h2>
        <p class="text-muted mb-4 fs-5">
            This item has been sold, reserved, or is no longer available to the public.
        </p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                <i class="bi bi-house-door me-2"></i> Back to Home
            </a>
            <a asp-controller="Items" asp-action="Index" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
                <i class="bi bi-search me-2"></i> Browse Items
            </a>
        </div>
    </div>
</div>
