@using MarketplaceApp.Models
@model IEnumerable<Item>

@{
    ViewData["Title"] = "Manage Items";
    Layout = "_AdminLayout"; // تأكد أن هذا الاسم يطابق ملف اللايوت الجديد
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-box-seam text-primary me-2"></i>Manage All Items</h2>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            Back to Dashboard
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Product</th>
                        <th>Price</th>
                        <th>Seller</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        @{
                                            // منطق جلب الصورة وإصلاح المسار
                                            var firstImage = item.Images?.FirstOrDefault()?.ImageUrl;
                                            string finalSrc = "/images/no-image.png"; // صورة افتراضية لو مفيش صورة

                                            if (!string.IsNullOrEmpty(firstImage))
                                            {
                                                if (firstImage.StartsWith("http"))
                                                {
                                                    finalSrc = firstImage;
                                                }
                                                else
                                                {
                                                    // نضمن أن المسار يبدأ بـ / لكي يبحث في wwwroot مباشرة
                                                    finalSrc = firstImage.StartsWith("/") ? firstImage : "/" + firstImage;
                                                }
                                            }
                                        }
                                        <img src="@finalSrc"
                                             class="rounded-3 border me-3"
                                             style="width: 50px; height: 50px; object-fit: cover;"
                                             onerror="this.src='/images/no-image.png';">
                                        
                                        <div>
                                            <div class="fw-bold">@item.Title</div>
                                            <small class="text-muted">ID: #@item.ItemID</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="fw-bold text-success">$@item.Price</td>
                                <td><i class="bi bi-person me-1"></i>@(item.User?.UserName ?? "Unknown")</td>
                                <td><span class="badge rounded-pill bg-info text-dark px-3">@item.Status</span></td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-controller="Items" asp-action="Details" asp-route-id="@item.ItemID"
                                           class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                            <i class="bi bi-eye"></i> View
                                        </a>

                                        <form asp-action="DeleteItem" asp-route-id="@item.ItemID" method="post" class="delete-form">
                                            @Html.AntiForgeryToken()
                                            <button type="button" class="btn btn-danger btn-sm rounded-pill px-3 btn-delete">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                No items found in the database.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            // التعامل مع زر الحذف
            $('.btn-delete').on('click', function (e) {
                var form = $(this).closest('form');
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to revert this!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });

            // إظهار رسائل النجاح
            @if (TempData["Success"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Done!',
                    text: '@TempData["Success"]',
                    timer: 3000,
                    showConfirmButton: false
                });
                </text>
            }
        });
    </script>
}