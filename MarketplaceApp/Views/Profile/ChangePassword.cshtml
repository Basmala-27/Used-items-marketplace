@model MarketplaceApp.Models.ChangePasswordVM

@{
    ViewData["Title"] = "Change Password";
}

<div class="container py-2">
    <!-- تقليل py من 5 لـ 2 -->
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- الهيدر البرتقالي مصغر -->
                <div class="p-3 text-white text-center" style="background-color: #FF6600;">
                    <div class="mb-1">
                        <i class="bi bi-shield-lock-fill" style="font-size: 2rem;"></i> <!-- صغرنا الأيقونة -->
                    </div>
                    <h4 class="fw-bold mb-0">Security Update</h4>
                    <p class="small opacity-75 mb-0" style="font-size: 0.75rem;">Update your account password</p>
                </div>

                <div class="card-body p-3 p-md-4">
                    <!-- تقليل p من 5 لـ 4 -->
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2 fw-bold"></div>

                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()

                        <!-- Current Password -->
                        <div class="mb-3">
                            <!-- تقليل mb من 4 لـ 3 -->
                            <label asp-for="CurrentPassword" class="form-label fw-bold text-secondary small mb-1"></label>
                            <div class="input-group input-group-sm">
                                <!-- إضافة sm لتصغير الحقل -->
                                <span class="input-group-text bg-light border-0 rounded-start-pill ps-3">
                                    <i class="bi bi-key text-muted"></i>
                                </span>
                                <input asp-for="CurrentPassword" class="form-control bg-light border-0 rounded-end-pill py-2 px-3" placeholder="Current password" type="password">
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger small ms-2" style="font-size: 0.7rem;"></span>
                        </div>

                        <hr class="my-3 opacity-25"> <!-- تقليل الـ margin للهامش -->
                        <!-- New Password -->
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-bold text-secondary small mb-1"></label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light border-0 rounded-start-pill ps-3">
                                    <i class="bi bi-lock-fill text-muted"></i>
                                </span>
                                <input asp-for="NewPassword" class="form-control bg-light border-0 rounded-end-pill py-2 px-3" placeholder="New password" type="password">
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small ms-2 d-block" style="font-size: 0.7rem;"></span>
                        </div>

                        <!-- Confirm Password -->
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold text-secondary small mb-1"></label>
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-light border-0 rounded-start-pill ps-3">
                                    <i class="bi bi-shield-check text-muted"></i>
                                </span>
                                <input asp-for="ConfirmPassword" class="form-control bg-light border-0 rounded-end-pill py-2 px-3" placeholder="Confirm password" type="password">
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small ms-2" style="font-size: 0.7rem;"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <!-- تقليل mt من 5 لـ 4 -->
                            <button type="submit" class="btn text-white rounded-pill py-2 fw-bold shadow-sm btn-update" style="background-color: #FF6600;">
                                Save Changes
                            </button>
                            <a asp-action="Edit" class="btn btn-link text-muted text-decoration-none btn-sm">
                                <i class="bi bi-arrow-left me-1"></i> Back to Profile
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
        .btn-update:hover {
            background-color: #e65c00 !important;
            transform: translateY(-1px);
            transition: 0.2s;
        }

        .form-control:focus {
            box-shadow: none;
            background-color: #fdfdfd !important;
            border: 1px solid #FF6600 !important;
        }
    </style>
}