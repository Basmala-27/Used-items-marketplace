@model IEnumerable<MarketplaceApp.Models.Notification>

<div class="container mt-4">
    <h4 class="mb-4"><i class="bi bi-bell-fill text-warning"></i> Notifications</h4>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-chat-dots" style="font-size: 3rem; color: #ccc;"></i>
            <p class="mt-3 text-muted">No notifications at the moment</p>
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var item in Model)
            {
                <div class="list-group-item list-group-item-action @(item.IsRead ? "" : "bg-light border-start border-primary border-4")">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <h6 class="mb-1 fw-bold">@item.MessageText</h6>
                        <small class="text-muted">@item.CreatedAt.ToString("g")</small>
                    </div>
                    @if (!string.IsNullOrEmpty(item.TargetUrl))
                    {
                        <a href="@item.TargetUrl" class="btn btn-sm btn-outline-primary mt-2">View Details</a>
                    }
                </div>
            }
        </div>
    }
</div>