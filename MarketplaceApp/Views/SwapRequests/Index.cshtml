@model IEnumerable<MarketplaceApp.Models.SwapRequest>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.OfferedItemId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RequestedItemId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Requester)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedAt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.OfferedItemId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RequestedItemId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Requester.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.SwapRequestId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.SwapRequestId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.SwapRequestId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
