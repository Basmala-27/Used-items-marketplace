@model Item

@{
    ViewData["Title"] = "Delete Item";
}

<div class="container mt-4">
    <h1 class="fw-bold">Delete</h1>
    <h3 class="text-danger">Are you sure you want to delete this item?</h3>
    <hr />

    <div class="row">
        <div class="col-md-10">
            <dl class="row">

                <!-- Title -->
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Title)</dt>
                <dd class="col-sm-9 fw-bold">@Html.DisplayFor(model => model.Title)</dd>

                <!-- Description -->
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Description)</dt>
                <dd class="col-sm-9 text-muted">@Html.DisplayFor(model => model.Description)</dd>

                <!-- Price -->
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Price)</dt>
                <dd class="col-sm-9 text-success fw-bold">@Model.Price.ToString("C")</dd>

                <!-- Condition & Location -->
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Condition)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Condition)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Location)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Location)</dd>

                <!-- Category -->
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Category)</dt>
                <dd class="col-sm-9">
                    @* ﾍ翩栁 聿 null 礦 聨橳 Include *@
                    @Model.Category?.Name
                </dd>

                <!-- Available For -->
                <dt class="col-sm-3">Available For</dt>
                <dd class="col-sm-9">
                    @if (Model.IsAvailableForSale)
                    {
                        <span class="badge bg-primary">Sale</span>
                    }
                    @if (Model.IsAvailableForSwap)
                    {
                        <span class="badge bg-warning text-dark ms-1">Swap</span>
                    }
                </dd>

                <!-- Status -->
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Status)</dt>
                <dd class="col-sm-9">
                    <span class="badge border text-dark bg-light">
                        @Html.DisplayFor(model => model.Status)
                    </span>
                </dd>

                <!-- Owner -->
                <dt class="col-sm-3">Owner</dt>
                <dd class="col-sm-9">
                    @Model.User?.Email
                </dd>

                <!-- Date -->
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.CreatedAt)</dd>

            </dl>

            <div class="mt-4 shadow-sm p-3 bg-light rounded border">

                <form asp-action="Delete"
                      onsubmit="return confirm('Are you sure you want to delete this item?');">

                    <input type="hidden" asp-for="ItemID" />

                    <button type="submit" class="btn btn-danger px-4 shadow-sm">
                        Confirm Delete
                    </button>

                    <span class="mx-2">|</span>

                    <a asp-action="Index" class="btn btn-secondary px-4 shadow-sm">
                        Back to List
                    </a>

                </form>

            </div>
        </div>
    </div>
</div>