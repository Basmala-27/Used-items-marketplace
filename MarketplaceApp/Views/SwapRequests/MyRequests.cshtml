@model IEnumerable<MarketplaceApp.Models.SwapRequest>
@using MarketplaceApp.Enums

@{
    ViewData["Title"] = "Swap Requests";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark">Swap Requests</h2>
            <p class="text-muted">Manage the trade offers you've received</p>
        </div>
        <span class="badge bg-orange px-3 py-2">@Model.Count() Total Requests</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded-4 bg-light border">
            <i class="bi bi-arrow-left-right display-1 text-muted mb-3"></i>
            <p class="fs-5 text-muted">No swap requests yet. Your items are still waiting for the right match!</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var request in Model)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden swap-request-card">
                        <div class="card-body p-0">
                            <div class="row g-0 align-items-center">

                                <!-- المنتج بتاعك (Your Item) -->
                                <div class="col-md-4 p-4 text-center border-end bg-light-gray">
                                    <small class="text-uppercase text-muted fw-bold d-block mb-2">Your Item</small>
                                    <h6 class="fw-bold mb-1">@request.RequestedItem?.Title</h6>
                                    <span class="text-orange fw-bold">$@request.RequestedItem?.Price</span>
                                    <div class="mt-2">
                                        <a asp-controller="Items" asp-action="Details" asp-route-id="@request.RequestedItemId" class="btn btn-sm btn-outline-secondary rounded-pill">View Yours</a>
                                    </div>
                                </div>

                                <!-- أيقونة التبادل في المنتصف -->
                                <div class="col-md-1 text-center py-3">
                                    <div class="bg-white shadow-sm border rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                        <i class="bi bi-arrow-left-right text-orange fs-5"></i>
                                    </div>
                                </div>

                                <!-- المنتج المعروض عليك (Offered Item) -->
                                <div class="col-md-4 p-4 text-center">
                                    <small class="text-uppercase text-muted fw-bold d-block mb-2">Offered Item</small>
                                    <h6 class="fw-bold mb-1">@request.OfferedItem?.Title</h6>
                                    <span class="text-success fw-bold">$@request.OfferedItem?.Price</span>
                                    <div class="mt-2">
                                        <a asp-controller="Items" asp-action="Details" asp-route-id="@request.OfferedItemId" class="btn btn-sm btn-orange rounded-pill">View Offer</a>
                                    </div>
                                </div>

                                <!-- قسم الأكشن والحالة -->
                                <div class="col-md-3 p-4 bg-light border-start text-center">
                                    <div class="mb-3">
                                        <small class="d-block text-muted mb-1">From: @request.Requester?.Email</small>
                                        <span class="badge @(request.Status == OfferStatus.Pending ? "bg-warning text-dark" : "bg-success") px-3">
                                            @request.Status
                                        </span>
                                    </div>

                                    @if (request.Status == OfferStatus.Pending)
                                    {
                                        <div class="d-grid gap-2">
                                            <form asp-action="Respond" method="post">
                                                <input type="hidden" name="id" value="@request.SwapRequestId" />
                                                <input type="hidden" name="status" value="Accepted" />
                                                <button type="submit" class="btn btn-success w-100 shadow-sm fw-bold">Accept Swap</button>
                                            </form>
                                            <form asp-action="Respond" method="post">
                                                <input type="hidden" name="id" value="@request.SwapRequestId" />
                                                <input type="hidden" name="status" value="Rejected" />
                                                <button type="submit" class="btn btn-outline-danger w-100">Decline</button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    :root {
        --main-orange: #FF8C00;
        --light-gray: #fcfcfc;
    }

    .bg-orange {
        background-color: var(--main-orange) !important;
        color: white;
    }

    .text-orange {
        color: var(--main-orange) !important;
    }

    .btn-orange {
        background-color: var(--main-orange);
        color: white;
        border: none;
    }

        .btn-orange:hover {
            background-color: #e67e00;
            color: white;
        }

    .bg-light-gray {
        background-color: var(--light-gray);
    }

    .rounded-4 {
        border-radius: 1.2rem !important;
    }

    .swap-request-card {
        transition: transform 0.2s ease, shadow 0.2s ease;
        border: 1px solid #eee !important;
    }

        .swap-request-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }

    .border-orange {
        border-color: var(--main-orange) !important;
    }
</style>