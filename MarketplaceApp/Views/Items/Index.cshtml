@model IEnumerable<Item>
@{
    ViewData["Title"] = ViewBag.CategoryName != null ? ViewBag.CategoryName + " — Items" : "All Items";

    string selectedCategory = ViewBag.SelectedCategory?.ToString() ?? "";
    string selectedCondition = ViewBag.SelectedCondition ?? "";
    string selectedListingType = ViewBag.SelectedListingType ?? "";
    string selectedSort = ViewBag.SelectedSort ?? "";
}


<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">
            @(ViewBag.CategoryName != null ? ViewBag.CategoryName : "All Items")
        </h2>
        <small class="text-muted">@Model.Count() item@(Model.Count() != 1 ? "s" : "") found</small>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Post Item</a>
</div>

<!-- Filter Bar -->
<form method="get" asp-action="Index" class="row g-2 mb-4">

    <!-- Hidden input to keep search results active while filtering -->
    <input type="hidden" name="searchTerm" value="@ViewBag.SearchTerm" />

    <!-- 1. All Categories -->
    <div class="col-md-3">
        <select name="categoryId" class="form-select" onchange="this.form.submit()">
            <option value="">All Categories</option>
            @foreach (var item in (SelectList)ViewBag.Categories)
            {
                <option value="@item.Value" selected="@(item.Value == selectedCategory)">@item.Text</option>
            }
        </select>
    </div>

    <!-- 2. All Conditions -->
    <div class="col-md-2">
        <select name="condition" class="form-select" onchange="this.form.submit()">
            <option value="all" selected="@(selectedCondition == "all")">All Conditions</option>
            <option value="Like New" selected="@(selectedCondition == "Like New")">Like New</option>
            <option value="Very Good" selected="@(selectedCondition == "Very Good")">Very Good</option>
            <option value="Good" selected="@(selectedCondition == "Good")">Good</option>
            <option value="Needs Repair" selected="@(selectedCondition == "Needs Repair")">Needs Repair</option>
        </select>
    </div>

    <!-- 3. Sale & Swap -->
    <div class="col-md-2">
        <select name="listingType" class="form-select" onchange="this.form.submit()">
            <option value="all" selected="@(selectedListingType == "all")">Sale & Swap</option>
            <option value="Sale" selected="@(selectedListingType == "Sale")">Sale</option>
            <option value="Swap" selected="@(selectedListingType == "Swap")">Swap</option>
        </select>
    </div>

    <!-- Listing Type Filter -->
    @* <div class="col-md-2">
        <select name="listingType" class="form-select" onchange="this.form.submit()">
            <option value="all">Sale &amp; Swap</option>
            @foreach (var lt in (SelectList)ViewBag.ListingTypes)
            {
                if (lt.Value == selectedListingType)
                {
                    <option value="@lt.Value" selected>@lt.Text</option>
                }
                else
                {
                    <option value="@lt.Value">@lt.Text</option>
                }
            }
        </select>
    </div> *@

    <!-- Sort -->
    <div class="col-md-2">
        <select name="sort" class="form-select" onchange="this.form.submit()">
            @if (selectedSort == "")
            {
                <option value="" selected>Newest First</option>
            }
            else
            {
                <option value="">Newest First</option>
            }
            @if (selectedSort == "price_asc")
            {
                <option value="price_asc" selected>Price: Low ? High</option>
            }
            else
            {
                <option value="price_asc">Price: Low ? High</option>
            }
            @if (selectedSort == "price_desc")
            {
                <option value="price_desc" selected>Price: High ? Low</option>
            }
            else
            {
                <option value="price_desc">Price: High ? Low</option>
            }
        </select>
    </div>

</form>

<!-- Items Grid -->
@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <p class="fs-5">No items found.</p>
        <a asp-action="Create" class="btn btn-outline-primary">Be the first to post one!</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">

                    <!-- Item Image -->
                    @if (item.Images != null && item.Images.Any())
                    {
                        <img src="@item.Images.First().ImageUrl"
                             class="card-img-top"
                             alt="@item.Title"
                             style="height: 180px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center"
                             style="height: 180px;">
                            <span class="text-muted small">No Image</span>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">

                        <!-- Category -->
                        <small class="text-muted mb-1">@item.Category?.Name</small>

                        <!-- Title -->
                        <h6 class="card-title mb-1 text-truncate" title="@item.Title">
                            @item.Title
                        </h6>

                        <!-- Price -->
                        <p class="fw-bold mb-2">$@item.Price.ToString("0.00")</p>

                        <!-- Condition + ListingType badges -->
                        <div class="d-flex gap-1 flex-wrap mb-2">
                            <span class="badge @(item.Condition == "Like New"     ? "bg-success"           :
                                                                                                                     item.Condition == "Very Good" ? "bg-primary" :
                                                                                                                     item.Condition == "Good" ? "bg-warning text-dark" :
                                                                                                                     item.Condition == "Needs Repair" ? "bg-danger" : "bg-secondary")">
                        @item.Condition
                    </span>

                    @if (item.ListingType == "Swap")
                            {
                                <span class="badge bg-info text-dark">Swap</span>
                            }
                        </div>

                        <!-- Location -->
                        @if (!string.IsNullOrEmpty(item.Location))
                        {
                            <small class="text-muted mb-2">?? @item.Location</small>
                        }

                        <!-- Actions -->
                        <div class="mt-auto d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.ItemID"
                               class="btn btn-sm btn-outline-primary flex-grow-1">View</a>
                            <a asp-action="Edit" asp-route-id="@item.ItemID"
                               class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.ItemID"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </div>

                    </div>

                    <!-- Card Footer: seller + date -->
                    <div class="card-footer text-muted d-flex justify-content-between"
                         style="font-size: 11px;">
                        <span>@item.User?.Email</span>
                        <span>@item.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>

                </div>
            </div>
        }
    </div>
}
