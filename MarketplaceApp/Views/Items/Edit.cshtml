@model MarketplaceApp.ViewModels.ItemEditViewModel

@{
    ViewData["Title"] = "Edit Item";
}

<div class="container mt-4">

    <div class="card shadow-sm border-0 rounded-4 p-4">

        <h3 class="mb-4 fw-bold">Edit Item</h3>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="ItemID" />
            <input type="hidden" asp-for="UserID" />

            <div class="row">

                <!-- Title -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Title</label>
                    <input asp-for="Title" class="form-control" />
                </div>

                <!-- Price -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Price</label>
                    <input asp-for="Price" class="form-control" />
                </div>

                <!-- Description -->
                <div class="col-12 mb-3">
                    <label class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <!-- Condition -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Condition</label>
                    <select asp-for="Condition"
                            class="form-control"
                            asp-items="ViewBag.Conditions">
                    </select>
                </div>

                <!-- Location -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Location</label>
                    <input asp-for="Location" class="form-control" />
                </div>

                <!-- Status -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Status</label>
                    <select asp-for="Status"
                            class="form-control"
                            asp-items="Html.GetEnumSelectList<MarketplaceApp.Enums.ItemStatus>()">
                    </select>
                </div>

                <!-- Category -->
                <div class="col-md-6 mb-3">
                    <label class="form-label">Category</label>
                    <select asp-for="CategoryID"
                            class="form-control"
                            asp-items="ViewBag.Categories">
                    </select>
                </div>

            </div>

            <!-- Buttons -->
            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    Save Changes
                </button>

                <a asp-action="Index" class="btn btn-secondary px-4">
                    Cancel
                </a>
            </div>

        </form>

    </div>

</div>