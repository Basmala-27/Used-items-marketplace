@model ItemCreateViewModel

@{
    ViewData["Title"] = "Post a New Item";
}

<div class="container mt-4 mb-5" style="max-width: 850px;">
    <!-- الهيدر المدمج -->
    <div class="mb-4 text-center">
        <h2 class="fw-bold">Post a New Item</h2>
        <p class="text-muted">Fill in the details to list your item on the marketplace</p>
    </div>

    <form asp-action="Create" enctype="multipart/form-data" method="post">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">

                <!-- قسم الصور: يجمع بين منطق الـ JS من النسخة 1 والتصميم من النسخة 2 -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Item Photos <span class="text-danger">*</span></label>
                    <div class="upload-container text-center p-4 border-dashed rounded-3" id="drop-zone" style="cursor: pointer; background-color: #fafafa; border: 2px dashed #d1d5db; transition: 0.3s;">

                        <div id="image-preview-container" class="mb-3 d-flex flex-wrap justify-content-center gap-2">
                            <!-- الصور ستظهر هنا بالـ JavaScript -->
                        </div>

                        <div id="upload-status" class="text-success fw-bold small mb-2" style="display:none;">
                            <i class="bi bi-check-circle-fill"></i> Images added successfully!
                        </div>

                        <div class="upload-icon-wrapper">
                            <i class="bi bi-camera fs-1 text-muted"></i>
                            <div class="mt-2 fw-bold">Click to upload or drag and drop</div>
                            <div class="text-muted small">PNG, JPG up to 10MB (Max 5 images)</div>
                        </div>

                        <input type="file" asp-for="ImageFiles" multiple class="d-none" id="file-input" accept="image/*" />
                    </div>
                    <span asp-validation-for="ImageFiles" class="text-danger small"></span>
                </div>

                <!-- العنوان -->
                <div class="mb-4">
                    <label asp-for="Title" class="form-label fw-bold">Item Title <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control form-control-lg rounded-3" placeholder="e.g., Sony WH-1000XM4 Wireless Headphones" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <!-- القسم والحالة -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="CategoryID" class="form-label fw-bold">Category <span class="text-danger">*</span></label>
                        <select asp-for="CategoryID" asp-items="ViewBag.Categories" class="form-select rounded-3">
                            <option value="">Select category</option>
                        </select>
                        <span asp-validation-for="CategoryID" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mt-3 mt-md-0">
                        <label asp-for="Condition" class="form-label fw-bold">Condition <span class="text-danger">*</span></label>
                        <select asp-for="Condition" asp-items="ViewBag.Conditions" class="form-select rounded-3">
                            <option value="">Select condition</option>
                        </select>
                        <span asp-validation-for="Condition" class="text-danger small"></span>
                    </div>
                </div>

                <!-- الوصف -->
                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-bold">Description <span class="text-danger">*</span></label>
                    <textarea asp-for="Description" class="form-control rounded-3" rows="5" placeholder="Tell buyers more about your item..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <!-- السعر والموقع -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label fw-bold">Price (USD) <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 rounded-start-3">$</span>
                            <input asp-for="Price" class="form-control border-start-0 rounded-end-3" placeholder="0.00" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mt-3 mt-md-0">
                        <label asp-for="Location" class="form-label fw-bold">Location <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 rounded-start-3"><i class="bi bi-geo-alt"></i></span>
                            <input asp-for="Location" class="form-control border-start-0 rounded-end-3" placeholder="City, State" />
                        </div>
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>
                </div>

                <!-- خيارات التعامل (Negotiation & Swap) - التنسيق الملون من النسخة 2 -->
                <div class="mb-4 p-3 rounded-3" style="background-color: #fff9f0; border: 1px solid #ffe8cc;">
                    <label class="form-label fw-bold text-orange d-block mb-3"><i class="bi bi-gear-wide-connected"></i> Deal Options</label>

                    <div class="row">
                        <div class="col-md-6 border-end">
                            <div class="form-check custom-option mb-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsAvailableForSale" id="negCheck">
                                <label class="form-check-label fw-bold" for="negCheck">
                                    Open for Negotiation
                                    <small class="d-block text-muted fw-normal">Allow users to offer a different price.</small>
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check custom-option mb-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsAvailableForSwap" id="swapCheck">
                                <label class="form-check-label fw-bold" for="swapCheck">
                                    Available for Swap
                                    <small class="d-block text-muted fw-normal">Interested in trading for another item.</small>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- أزرار التحكم -->
                <div class="d-flex flex-column flex-md-row gap-3 mt-5">
                    <button type="submit" class="btn btn-orange btn-lg flex-grow-1 py-3 fw-bold shadow-sm rounded-pill">
                        <i class="bi bi-plus-circle me-2"></i> Post My Item
                    </button>
                    <a asp-action="Index" class="btn btn-light btn-lg border px-5 py-3 rounded-pill text-muted fw-bold">Cancel</a>
                </div>

            </div>
        </div>
    </form>
</div>

<style>
    .text-orange {
        color: #FF8C00;
    }

    .btn-orange {
        background-color: #FF8C00;
        color: white;
        transition: 0.3s;
        border: none;
    }

        .btn-orange:hover {
            background-color: #e67e00;
            color: white;
            transform: translateY(-2px);
        }

    .form-control:focus, .form-select:focus {
        border-color: #FF8C00;
        box-shadow: 0 0 0 0.25rem rgba(255, 140, 0, 0.15);
    }

    .border-dashed:hover {
        border-color: #FF8C00 !important;
        background-color: #fffaf5 !important;
    }

    .custom-option .form-check-input:checked {
        background-color: #FF8C00;
        border-color: #FF8C00;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const dropZone = document.getElementById('drop-zone');
        const fileInput = document.getElementById('file-input');
        const previewContainer = document.getElementById('image-preview-container');
        const uploadStatus = document.getElementById('upload-status');
        const uploadIconWrapper = document.querySelector('.upload-icon-wrapper');

        let selectedFiles = [];

        dropZone.addEventListener('click', (e) => {
            if (e.target.tagName !== 'SPAN') fileInput.click();
        });

        fileInput.addEventListener('change', function () {
            const newFiles = Array.from(this.files);
            selectedFiles = selectedFiles.concat(newFiles);
            updateUI();
        });

        function updateUI() {
            previewContainer.innerHTML = '';
            if (selectedFiles.length > 0) {
                uploadStatus.style.display = 'block';
                uploadIconWrapper.style.display = 'none';
                uploadStatus.innerHTML = `<i class="bi bi-check-circle-fill"></i> ${selectedFiles.length} images selected`;

                selectedFiles.forEach((file, index) => {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        const imgWrapper = document.createElement('div');
                        imgWrapper.className = "position-relative";
                        imgWrapper.style.width = "100px";
                        imgWrapper.innerHTML = `
                            <img src="${e.target.result}" class="img-thumbnail shadow-sm" style="width: 100px; height: 100px; object-fit: cover; border-radius: 12px;">
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger border border-light"
                                  style="cursor:pointer; z-index: 10; padding: 5px 8px;"
                                  onclick="removeFile(${index}, event)">×</span>
                        `;
                        previewContainer.appendChild(imgWrapper);
                    };
                    reader.readAsDataURL(file);
                });
                syncFilesToInput();
            } else {
                uploadStatus.style.display = 'none';
                uploadIconWrapper.style.display = 'block';
            }
        }

        window.removeFile = function(index, event) {
            event.stopPropagation();
            selectedFiles.splice(index, 1);
            updateUI();
        };

        function syncFilesToInput() {
            const dataTransfer = new DataTransfer();
            selectedFiles.forEach(file => dataTransfer.items.add(file));
            fileInput.files = dataTransfer.files;
        }

        // Drag & Drop
        dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.style.borderColor = '#FF8C00'; });
        dropZone.addEventListener('dragleave', () => { dropZone.style.borderColor = '#d1d5db'; });
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            const droppedFiles = Array.from(e.dataTransfer.files);
            selectedFiles = selectedFiles.concat(droppedFiles);
            updateUI();
        });
    </script>
}