@model MarketplaceApp.ViewModels.SubmitComplaintVM

@{
    ViewData["Title"] = "Submit Complaint";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-danger text-white rounded-top-4 py-3">
                    <h4 class="mb-0 text-center"><i class="bi bi-exclamation-triangle-fill me-2"></i> Submit a Complaint</h4>
                </div>
                <div class="card-body p-4">
                    <p class="text-muted text-center mb-4">
                        Please provide details about your issue. Our admin team will review it shortly.
                    </p>

                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="TargetUserId" />
                        <input type="hidden" asp-for="TargetItemId" />

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold"></label>
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="Briefly describe the issue..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold"></label>
                            <textarea asp-for="Description" class="form-control" rows="5" placeholder="Provide as much detail as possible..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold">
                                <i class="bi bi-send-fill me-2"></i> Submit Complaint
                            </button>
                            <a href="javascript:history.back()" class="btn btn-light rounded-pill">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
