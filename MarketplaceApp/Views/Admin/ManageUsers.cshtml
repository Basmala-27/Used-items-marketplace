
@using MarketplaceApp.Models
@model IEnumerable<ApplicationUser>

@{
    ViewData["Title"] = "Manage Users";
    Layout = "_AdminLayout";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="bi bi-people-fill text-primary me-2"></i>Manage Users</h2>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            Back to Dashboard
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">User</th>
                        <th class="py-3">Email</th>
                        <th class="py-3">Status</th>
                        <th class="text-center py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <a asp-controller="Profile" asp-action="SellerProfile" asp-route-id="@user.Id" class="text-decoration-none d-flex align-items-center text-dark profile-link">
                                    <div class="me-3 position-relative">
                                        <img src="@(string.IsNullOrEmpty(user.ProfileImage) ? "/images/default-profile.png" : user.ProfileImage)"
                                             class="rounded-circle border shadow-sm"
                                             style="width: 48px; height: 48px; object-fit: cover;"
                                             onerror="this.src='/images/default-profile.png'">
                                    </div>
                                    <div>
                                        <div class="fw-bold mb-0">@user.Name</div>
                                        <small class="text-muted" style="font-size: 0.7rem;">
                                            View Seller Profile <i class="bi bi-arrow-up-right ms-1"></i>
                                        </small>
                                    </div>
                                </a>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @if (user.IsBlocked)
                                {
                                    <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">Blocked</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">Active</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <form asp-action="ToggleBlockUser" asp-route-userId="@user.Id" method="post">
                                        <button type="submit" class="btn @(user.IsBlocked ? "btn-success" : "btn-outline-warning") btn-sm px-3 rounded-pill">
                                            <i class="bi @(user.IsBlocked ? "bi-unlock" : "bi-slash-circle") me-1"></i>
                                            @(user.IsBlocked ? "Unblock" : "Block User")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .profile-link {
        transition: all 0.2s ease-in-out;
        padding: 5px;
        border-radius: 10px;
    }

        .profile-link:hover {
            background-color: #f8f9fa;
        }

            .profile-link:hover .fw-bold {
                color: #FF6600;
            }

            .profile-link:hover img {
                transform: scale(1.05);
                border-color: #FF6600 !important;
            }

    .bg-danger-subtle {
        background-color: #ffe5e7 !important;
    }

    .bg-success-subtle {
        background-color: #e1f7ec !important;
    }
</style>
@if (TempData["Error"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        Swal.fire({
            icon: 'error',
            title: 'Action Not Allowed',
            text: '@TempData["Error"]'
        });
    </script>
}