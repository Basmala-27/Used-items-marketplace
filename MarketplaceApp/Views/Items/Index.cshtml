@model IEnumerable<Item>
@{
    ViewData["Title"] = "Marketplace - Negotiation & Swap";
    string selectedCategory = ViewBag.SelectedCategory?.ToString() ?? "";
    string selectedCondition = ViewBag.SelectedCondition ?? "";
    string selectedListingType = ViewBag.SelectedListingType ?? "";
    string selectedSort = ViewBag.SelectedSort ?? "";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark">@(ViewBag.CategoryName ?? "Explore Marketplace")</h2>
        <p class="text-muted small">Find items for <span class="text-orange fw-bold">Negotiation</span> or <span class="text-warning fw-bold">Swap</span></p>
    </div>
    <a asp-action="Create" class="btn btn-orange shadow-sm px-4 rounded-pill">+ Post Item</a>
</div>

<!-- Filter Bar -->
<form method="get" asp-action="Index" class="row g-2 mb-4 bg-light p-3 rounded-3 shadow-sm border">
    <div class="col-md-3">
        <select name="categoryId" class="form-select border-0 shadow-none" onchange="this.form.submit()">
            <option value="">All Categories</option>
            @foreach (var cat in (SelectList)ViewBag.Categories)
            {
                <option value="@cat.Value" selected="@(cat.Value == selectedCategory)">@cat.Text</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <select name="condition" class="form-select border-0 shadow-none" onchange="this.form.submit()">
            <option value="all">All Conditions</option>
            @foreach (var cond in (SelectList)ViewBag.Conditions)
            {
                <option value="@cond.Value" selected="@(cond.Value == selectedCondition)">@cond.Text</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <select name="listingType" class="form-select border-0 shadow-none" onchange="this.form.submit()">
            <option value="all">Negotiation & Swap</option>
            <option value="Sale" selected="@(selectedListingType == "Sale")">Open for Negotiation</option>
            <option value="Swap" selected="@(selectedListingType == "Swap")">Available for Swap</option>
        </select>
    </div>

    <div class="col-md-2 ms-auto">
        <select name="sort" class="form-select border-0 shadow-none" onchange="this.form.submit()">
            <option value="">Newest First</option>
            <option value="price_asc">Price: Low to High</option>
            <option value="price_desc">Price: High to Low</option>
        </select>
    </div>
</form>

<!-- Items Grid -->
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var item in Model)
    {
        <div class="col">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative item-card">
                <!-- Negotiable Badge on Image -->
                @if (item.IsAvailableForSale)
                {
                    <span class="badge rounded-pill bg-white text-primary border border-primary position-absolute top-0 end-0 m-2 shadow-sm z-index-1">
                        Negotiable
                    </span>
                }

                <!-- Item Image -->
                <div class="image-container" style="height: 200px; background: #eee;">
                    @if (item.Images != null && item.Images.Any())
                    {
                        <img src="@item.Images.First().ImageUrl" class="card-img-top h-100 w-100 object-fit-cover" alt="@item.Title">
                    }
                    else
                    {
                        <div class="h-100 d-flex align-items-center justify-content-center text-muted">No Image</div>
                    }
                </div>

                <div class="card-body d-flex flex-column p-3">
                    <small class="text-muted">@item.Category?.Name</small>
                    <h6 class="fw-bold text-dark text-truncate mb-1">@item.Title</h6>
                    <h5 class="text-orange fw-bold mb-2">$@item.Price.ToString("0.00")</h5>

                    <div class="d-flex gap-1 flex-wrap mb-3">
                        <span class="badge bg-light text-dark border">@item.Condition</span>
                        @if (item.IsAvailableForSwap)
                        {
                            <span class="badge bg-warning-light text-dark border border-warning">Swap</span>
                        }
                    </div>

                    <div class="mt-auto">
                        <a asp-action="Details" asp-route-id="@item.ItemID" class="btn btn-outline-orange w-100 rounded-pill btn-sm">View Details</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .text-orange {
        color: #FF8C00 !important;
    }

    .btn-orange {
        background-color: #FF8C00;
        color: white;
        border: none;
        transition: 0.3s;
    }

        .btn-orange:hover {
            background-color: #e67e00;
            color: white;
            transform: translateY(-2px);
        }

    .btn-outline-orange {
        color: #FF8C00;
        border: 1px solid #FF8C00;
        transition: 0.3s;
    }

        .btn-outline-orange:hover {
            background-color: #FF8C00;
            color: white;
        }

    .bg-warning-light {
        background-color: #fff9e6;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    .item-card {
        transition: 0.3s;
    }

        .item-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .object-fit-cover {
        object-fit: cover;
    }
</style>